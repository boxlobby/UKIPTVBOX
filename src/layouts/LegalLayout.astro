---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, waLink } from '../data/site';

export interface Props {
  title: string;
  description: string;
  eyebrow: string;
  heading: string;
  intro: string;
  updated: string;
  noIndex?: boolean;
  includeSchema?: boolean;
}

const { title, description, eyebrow, heading, intro, updated, noIndex = true, includeSchema = false } = Astro.props;
---
<BaseLayout title={`${title} | ${site.name}`} description={description} noIndex={noIndex} includeSchema={includeSchema}>
  <Header />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border-subtle">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-70">
        <div class="absolute -top-40 left-1/2 h-[520px] w-[820px] -translate-x-1/2 rounded-full bg-grad-brand-soft blur-3xl"></div>
      </div>
      <div class="container-x pt-20 pb-16 md:pt-28 md:pb-20 max-w-3xl">
        <span class="eyebrow">{eyebrow}</span>
        <h1 class="mt-5 font-display text-4xl md:text-5xl font-bold tracking-tight text-text-primary">
          {heading}
        </h1>
        <p class="mt-5 text-lg text-text-muted leading-relaxed">{intro}</p>
        <p class="mt-6 inline-flex items-center gap-2 text-xs uppercase tracking-widest text-text-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-light"></span>
          Last updated: {updated}
        </p>
      </div>
    </section>

    <!-- Body -->
    <section class="container-x py-14 md:py-20 max-w-3xl">
      <article class="legal-prose">
        <slot />
      </article>

      <!-- Contact card -->
      <aside class="mt-16 card p-6 md:p-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-text-muted">Questions?</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-text-primary">Get in touch</h2>
        <p class="mt-3 text-text-muted">
          Our UK support team is here to help with anything related to this policy or your subscription.
        </p>
        <div class="mt-6">
          <a
            href={waLink()}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-[#25d366] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-[#25d366]/30 transition-colors hover:bg-[#1ebe5d] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25d366]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Start chat on WhatsApp
          </a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
