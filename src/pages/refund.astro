---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Refund Policy | IPTV Trial" description="Our refund policy." noIndex includeSchema={false}>
  <Header />
  <main id="main" class="container-x py-24 max-w-3xl mx-auto">
    <span class="eyebrow">Refunds</span>
    <h1 class="mt-6 text-4xl md:text-5xl font-bold">Refund Policy</h1>
    <p class="mt-6 text-text-muted">Full refund policy coming soon. If the service isn’t working on your setup and we can’t resolve it, we offer a refund within the first 24 hours of activation.</p>
  </main>
  <Footer />
</BaseLayout>
