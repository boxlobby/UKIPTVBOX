---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Privacy Policy | IPTV Trial" description="Our privacy policy — how we handle your data." noIndex includeSchema={false}>
  <Header />
  <main id="main" class="container-x py-24 max-w-3xl mx-auto">
    <span class="eyebrow">Privacy</span>
    <h1 class="mt-6 text-4xl md:text-5xl font-bold">Privacy Policy</h1>
    <p class="mt-6 text-text-muted">Full privacy policy coming soon. In the meantime, contact us for any questions about how we handle your data.</p>
  </main>
  <Footer />
</BaseLayout>
