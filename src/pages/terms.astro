---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Terms of Service | IPTV Trial" description="Terms of service." noIndex includeSchema={false}>
  <Header />
  <main id="main" class="container-x py-24 max-w-3xl mx-auto">
    <span class="eyebrow">Terms</span>
    <h1 class="mt-6 text-4xl md:text-5xl font-bold">Terms of Service</h1>
    <p class="mt-6 text-text-muted">Full terms of service coming soon.</p>
  </main>
  <Footer />
</BaseLayout>
