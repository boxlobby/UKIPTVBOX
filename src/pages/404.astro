---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Page not found | IPTV Trial" description="The page you’re looking for doesn’t exist." noIndex includeSchema={false}>
  <Header />
  <main id="main" class="container-x py-32 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-6 text-4xl md:text-6xl font-bold">Page not found</h1>
    <p class="mt-4 text-text-muted">The page you’re looking for has moved or doesn’t exist.</p>
    <a href="/" class="btn-primary mt-8">Back to home</a>
  </main>
  <Footer />
</BaseLayout>
