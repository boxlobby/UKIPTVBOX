---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { site, packages, waLink, waLinkPackage } from '../data/site';

const title = 'IPTV Subscription UK Pricing: Plans from £14.99 | UK IPTV BOX';
const description =
  'Compare all UK IPTV BOX subscription plans from £14.99. 50,000+ live channels, 200,000+ movies & series, 4K quality, instant activation. No contract, no auto-renewal.';
const canonical = `${site.url}/pricing`;

const pricingFaqs = [
  {
    q: 'Which IPTV subscription plan offers the best value?',
    a: "The 12-month plan at £49.99 is our best value option: you save £129.89 compared to paying monthly and get a free Premium IPTV Player App worth £9.99. If you'd rather not commit for a full year, the 6-month plan at £36.99 saves over £52 and still brings your monthly cost well below the 1-month price.",
  },
  {
    q: 'Can I upgrade my IPTV plan part-way through?',
    a: 'Yes. Message us on WhatsApp and we will apply the remaining value of your current plan as credit towards the upgrade. You never lose money switching to a longer subscription.',
  },
  {
    q: 'What payment methods do you accept?',
    a: 'We accept bank transfer, debit and credit card, Apple Pay, and Google Pay. Every transaction is processed securely and you receive instant confirmation once payment is complete.',
  },
  {
    q: 'Is there a free IPTV trial before I buy?',
    a: 'Message us on WhatsApp before purchasing and we can arrange a brief live demo so you can confirm the service streams cleanly on your exact device and internet connection.',
  },
  {
    q: 'Do you offer a money-back guarantee?',
    a: 'Yes, we offer a 7-day money-back guarantee. If we cannot resolve a technical issue within 48 hours of you reporting it, we will issue a full refund, no questions asked.',
  },
  {
    q: 'How many simultaneous connections does each plan include?',
    a: 'Every plan includes one simultaneous connection. Need more screens for separate rooms or family members? Ask us on WhatsApp for a discounted multi-connection package.',
  },
  {
    q: 'Are there hidden fees or automatic renewals?',
    a: 'None. You pay once for your chosen plan period. There is no recurring charge, no auto-renewal, and no hidden fees. When your subscription ends you simply choose whether to renew.',
  },
  {
    q: 'Does every plan include all channels and VOD content?',
    a: 'Yes, every plan gives you full access to 50,000+ live channels and 200,000+ movies and series. There are no tiered content locks or premium add-ons. One price, everything included.',
  },
];

const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      inLanguage: 'en-GB',
      isPartOf: { '@id': `${site.url}/#website` },
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonical}#faq`,
      mainEntity: pricingFaqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
    {
      '@type': 'ItemList',
      '@id': `${canonical}#plans`,
      name: 'UK IPTV BOX Subscription Plans',
      itemListElement: packages.map((pkg, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: `${pkg.label} UK IPTV Subscription`,
        description: `${pkg.label} plan for £${pkg.price}${pkg.save ? `. Save £${pkg.save} vs monthly.` : ''}`,
      })),
    },
  ],
});

const compareRows = [
  { label: 'Duration',             values: ['1 Month',   '3 Months',  '6 Months',  '12 Months'] },
  { label: 'Total Price',          values: ['£14.99',    '£26.99',    '£36.99',    '£49.99']    },
  { label: 'Price Per Month',      values: ['£14.99',    '£9.00',     '£6.17',     '£4.17']     },
  { label: 'You Save',             values: ['—',         '£17.98',    '£52.95',    '£129.89']   },
  { label: 'Live Channels',        values: ['50,000+',   '50,000+',   '50,000+',   '50,000+']   },
  { label: 'Movies & Series',      values: ['200,000+',  '200,000+',  '200,000+',  '200,000+']  },
  { label: '4K / HD Streams',      values: [true, true, true, true] },
  { label: 'UK Sports Channels',   values: [true, true, true, true] },
  { label: 'Anti-Buffer Servers',  values: [true, true, true, true] },
  { label: 'Instant Activation',   values: [true, true, true, true] },
  { label: 'All Devices',          values: [true, true, true, true] },
  { label: 'VPN Protection',       values: [true, true, true, true] },
  { label: '24/7 WA Support',      values: [true, true, true, true] },
  { label: 'No Auto-Renewal',      values: [true, true, true, true] },
  { label: '7-Day Money Back',     values: [true, true, true, true] },
  { label: 'Free Premium App',     values: [false, false, false, true] },
];

const guarantees = [
  { icon: 'shield',       title: 'Secure Payment',        body: 'Bank transfer, card, Apple Pay and Google Pay, all processed over an encrypted connection.' },
  { icon: 'clock',        title: '7-Day Money Back',      body: 'If we cannot fix a technical issue within 48 hours, you get a full refund. No questions asked.' },
  { icon: 'refresh-ccw',  title: 'No Auto-Renewal',       body: 'We will never charge you again without your explicit permission. You stay in complete control.' },
  { icon: 'zap',          title: 'Instant Activation',    body: 'Your subscription goes live within minutes of payment, any time, day or night.' },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  includeSchema={false}
>
  <script is:inline type="application/ld+json" set:html={schemaJson} />

  <Header />

  <main id="main">

    <!-- ═══ HERO ═══ -->
    <section style="background:#241056;padding:72px 0 56px;">
      <div class="container-x text-center">
        <span style="display:inline-flex;align-items:center;gap:8px;border-radius:999px;border:1px solid rgba(211,249,79,.25);background:rgba(211,249,79,.08);padding:5px 16px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:#D3F94F;">
          UK IPTV Subscription Pricing
        </span>

        <h1 class="mt-5 text-4xl sm:text-5xl md:text-6xl font-bold leading-tight" style="color:#F1EEFA;max-width:820px;margin-left:auto;margin-right:auto;">
          Best UK IPTV Subscription<br />
          <span style="background:linear-gradient(135deg,#E4FB8A,#D3F94F 55%,#B8E437 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">Plans from £14.99</span>
        </h1>

        <p class="mx-auto mt-5 max-w-2xl text-base sm:text-lg leading-relaxed" style="color:#DDD3F5;">
          Every plan includes 50,000+ live channels, 200,000+ movies &amp; series, 4K quality, and instant activation.
          No contract. No auto-renewal. No hidden fees. Just the UK's most reliable IPTV service.
        </p>

        <ul class="mt-8 flex flex-wrap items-center justify-center gap-3 text-xs font-semibold" style="color:#E4FB8A;">
          {[
            { icon: 'clock',   text: '7 days money back' },
            { icon: 'zap',     text: 'Instant activation' },
            { icon: 'shield',  text: 'VPN Protected' },
            { icon: 'lock',    text: 'No auto-renewal' },
          ].map(({ icon, text }) => (
            <li style="display:inline-flex;align-items:center;gap:6px;background:rgba(211,249,79,.08);border:1px solid rgba(211,249,79,.2);border-radius:999px;padding:5px 14px;">
              <span style="color:#D3F94F;"><Icon name={icon} size={13} /></span>
              {text}
            </li>
          ))}
        </ul>

        <div class="mt-9">
          <a href="#pricing" class="btn-primary px-8 py-4 text-base inline-flex items-center gap-2">
            See All Plans &amp; Pricing
            <Icon name="chevron-down" size={18} />
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ PRICING CARDS ═══ -->
    <section id="pricing" class="section" style="background:#241056;">
      <div class="w-full px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span style="display:inline-flex;align-items:center;gap:8px;border-radius:999px;border:1px solid rgba(211,249,79,.25);background:rgba(211,249,79,.08);padding:5px 14px;font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:.18em;color:#D3F94F;">Choose Your Plan</span>
          <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold" style="color:#F1EEFA;">UK IPTV Subscription Plans</h2>
          <p class="mt-4 text-sm sm:text-base leading-relaxed" style="color:#DDD3F5;">
            All plans unlock the full channel and VOD library. The longer you subscribe, the less you pay per month.
            Save up to <strong style="color:#D3F94F;">£129.89</strong> on our annual plan.
          </p>
        </div>

        <div class="mt-10 md:mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {packages.map((pkg) => (
            <div
              class={`relative rounded-2xl p-6 flex flex-col ${pkg.popular ? 'annual-card' : ''}`}
              style={pkg.popular
                ? 'border:1px solid #D3F94F;background:#4B22AC;border-radius:20px;'
                : 'border:1px solid rgba(211,249,79,.15);background:#2E1770;border-radius:20px;'}
            >
              {pkg.badge && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand px-3 py-1 text-[11px] font-bold uppercase tracking-wider shadow-glow whitespace-nowrap" style="color:#241056;">
                  {pkg.badge}
                </span>
              )}

              <div>
                <p class="text-[11px] font-semibold uppercase tracking-widest" style="color:#E4FB8A;">{pkg.label} Plan</p>
                <div class="mt-3 flex items-end gap-2">
                  <span class="text-4xl sm:text-5xl font-display font-bold leading-none" style="background:linear-gradient(135deg,#E4FB8A,#D3F94F 55%,#B8E437 100%);-webkit-background-clip:text;background-clip:text;color:transparent;">
                    {site.currencySymbol}{pkg.price}
                  </span>
                </div>
                <p class="mt-1 text-xs font-medium" style="color:#DDD3F5;">
                  {site.currencySymbol}{pkg.perMonth.toFixed(2)}/month &middot; one-time payment
                </p>
                {pkg.save && (
                  <p class="mt-1 text-xs font-bold" style="color:#D3F94F;">You save £{pkg.save.toFixed(2)}</p>
                )}
              </div>

              <ul class="mt-6 space-y-3 flex-1 text-sm font-medium leading-snug" style="color:#F1EEFA;">
                {[
                  '50,000+ live channels',
                  '200,000+ movies & series',
                  '4K / FHD / HD streams',
                  'UK & international sports',
                  '99.9% uptime servers',
                  'Instant activation',
                  'All devices supported',
                  'VPN protection included',
                  '24/7 WhatsApp support',
                  'No auto-renewal',
                  '7-day money-back guarantee',
                ].map((line) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full shrink-0" style="background:rgba(255,255,255,.18);">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    </span>
                    {line}
                  </li>
                ))}
                {pkg.id === 'annual' && (
                  <li class="flex items-start gap-3 mt-2">
                    <span class="mt-0.5 shrink-0" style="color:#D3F94F;"><Icon name="gift" size={18} /></span>
                    <span>
                      <span style="color:#D3F94F;">Free Gift:</span>{' '}
                      <span>Premium IPTV Player App</span>
                      <span class="ml-1.5 text-[10px] font-bold uppercase tracking-wide rounded-full px-2 py-0.5" style="background:rgba(211,249,79,.15);color:#D3F94F;border:1px solid rgba(211,249,79,.35);">£9.99 value</span>
                    </span>
                  </li>
                )}
              </ul>

              <div class="mt-7">
                <a
                  href={waLinkPackage(pkg)}
                  class={`w-full py-3.5 text-sm font-semibold rounded-xl inline-flex items-center justify-center gap-2 transition-all ${pkg.popular ? 'annual-btn' : ''}`}
                  style="background:#D3F94F;color:#241056;box-shadow:0 0 40px -8px rgba(211,249,79,.35);"
                  target="_blank"
                  rel="nofollow noopener noreferrer"
                >
                  Subscribe · {site.currencySymbol}{pkg.price}
                  <Icon name="arrow" size={15} />
                </a>
              </div>

              <div class="mt-4">
                <div class="flex items-center justify-center gap-1.5 mb-2.5">
                  <span class="text-success shrink-0"><Icon name="lock" size={11} /></span>
                  <span class="text-[10px] font-semibold text-success tracking-wide">Secure &amp; encrypted payment</span>
                </div>
                <div class="flex items-center justify-center gap-1 flex-wrap">
                  <!-- Visa -->
                  <svg width="36" height="23" viewBox="0 0 36 23" role="img" aria-label="Visa" xmlns="http://www.w3.org/2000/svg"><rect width="36" height="23" rx="3" fill="#1A1F71"/><text x="18" y="15.5" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="10" font-weight="900" font-style="italic" fill="#FFFFFF" letter-spacing="1">VISA</text></svg>
                  <!-- Mastercard -->
                  <svg width="36" height="23" viewBox="0 0 36 23" role="img" aria-label="Mastercard" xmlns="http://www.w3.org/2000/svg"><rect width="36" height="23" rx="3" fill="#1D1D1D"/><circle cx="13.5" cy="11.5" r="6.5" fill="#EB001B"/><circle cx="22.5" cy="11.5" r="6.5" fill="#F79E1B"/><path d="M18 4.81A6.5 6.5 0 0 1 22.5 11.5 6.5 6.5 0 0 1 18 18.19 6.5 6.5 0 0 1 13.5 11.5 6.5 6.5 0 0 1 18 4.81Z" fill="#FF5F00"/></svg>
                  <!-- Apple Pay -->
                  <svg width="36" height="23" viewBox="0 0 36 23" role="img" aria-label="Apple Pay" xmlns="http://www.w3.org/2000/svg"><rect width="36" height="23" rx="3" fill="#000"/><path d="M12.8 5.1c.45-.55.78-1.32.7-2.1-.68.04-1.5.46-1.98 1.02-.43.5-.78 1.28-.7 2.04.75.05 1.52-.38 1.98-.96zm.78 1.12c-1.1-.06-2.04.63-2.57.63-.54 0-1.36-.6-2.25-.58-1.16.02-2.23.67-2.82 1.72-1.2 2.08-.32 5.17.86 6.87.57.84 1.25 1.77 2.15 1.74.85-.03 1.17-.55 2.2-.55 1.03 0 1.32.55 2.22.53.9-.02 1.48-.84 2.05-1.68.63-.94.89-1.86.91-1.9-.04-.02-1.77-.69-1.79-2.74-.02-1.73 1.41-2.55 1.47-2.6-.8-1.18-2.05-1.44-2.43-1.44z" fill="white"/><text x="26.5" y="15.5" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,Arial,sans-serif" font-size="7.5" font-weight="600" fill="white">Pay</text></svg>
                  <!-- Google Pay -->
                  <svg width="36" height="23" viewBox="0 0 36 23" role="img" aria-label="Google Pay" xmlns="http://www.w3.org/2000/svg"><rect width="36" height="23" rx="3" fill="white" stroke="#DADCE0" stroke-width="0.75"/><text x="9.5" y="16" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="700" fill="#4285F4">G</text><text x="26" y="16" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="8.5" font-weight="500" fill="#3C4043">Pay</text></svg>
                  <!-- Bank Transfer -->
                  <svg width="36" height="23" viewBox="0 0 36 23" role="img" aria-label="Bank Transfer" xmlns="http://www.w3.org/2000/svg"><rect width="36" height="23" rx="3" fill="#374151"/><polygon points="18,3.5 6.5,9 29.5,9" fill="white" opacity=".92"/><rect x="8" y="9.5" width="2" height="6" fill="white" opacity=".9"/><rect x="12" y="9.5" width="2" height="6" fill="white" opacity=".9"/><rect x="16" y="9.5" width="2" height="6" fill="white" opacity=".9"/><rect x="20" y="9.5" width="2" height="6" fill="white" opacity=".9"/><rect x="24" y="9.5" width="2" height="6" fill="white" opacity=".9"/><rect x="6.5" y="16" width="23" height="1.5" fill="white" opacity=".9"/></svg>
                  <!-- Bitcoin / Crypto -->
                  <svg width="36" height="23" viewBox="0 0 36 23" role="img" aria-label="Bitcoin / Crypto" xmlns="http://www.w3.org/2000/svg"><rect width="36" height="23" rx="3" fill="#F7931A"/><text x="18" y="16.5" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="13" font-weight="900" fill="white">₿</text></svg>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- per-month breakdown bar -->
        <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {packages.map((pkg) => (
            <div class="rounded-xl text-center py-4 px-3" style="background:rgba(211,249,79,.06);border:1px solid rgba(211,249,79,.12);">
              <p class="text-[11px] uppercase tracking-wider font-semibold" style="color:#DDD3F5;">{pkg.label}</p>
              <p class="mt-1 text-2xl font-bold" style="color:#D3F94F;">{site.currencySymbol}{pkg.perMonth.toFixed(2)}<span class="text-sm font-normal" style="color:#DDD3F5;">/mo</span></p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ WHAT'S INCLUDED ═══ -->
    <section id="whats-included" class="section" style="background:#EDEAF5;">
      <div class="container-x">
        <div class="mx-auto max-w-2xl text-center">
          <span style="display:inline-flex;align-items:center;gap:8px;border-radius:999px;border:1px solid rgba(91,46,190,.25);background:rgba(91,46,190,.08);padding:5px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:#5B2EBE;">Everything Included</span>
          <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold" style="color:#241056;">What You Get With Every Plan</h2>
          <p class="mt-4 text-sm sm:text-base leading-relaxed" style="color:#5B2EBE;">
            Whether you choose 1 month or 12 months, every UK IPTV BOX subscription ships with
            the complete feature set from day one. No upsells, no locked tiers, no compromises.
          </p>
        </div>

        <div class="mt-10 md:mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">

          <!-- Card 1 -->
          <div class="rounded-2xl p-7" style="background:#fff;border:1px solid rgba(91,46,190,.12);box-shadow:0 2px 16px rgba(91,46,190,.07);">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background:#5B2EBE;color:#D3F94F;">
              <Icon name="tv" size={22} />
            </div>
            <h3 class="text-lg font-bold" style="color:#241056;">50,000+ Live Channels</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:#5B2EBE;">
              One of the largest UK IPTV channel lineups available. Every major feed is included: <strong style="color:#241056;">BBC, ITV, Sky, BT Sport, Premier League,</strong> news, kids, entertainment, and 150+ international channels.
              Sorted by how people actually browse, not dumped in one long alphabetical list.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="rounded-2xl p-7" style="background:#fff;border:1px solid rgba(91,46,190,.12);box-shadow:0 2px 16px rgba(91,46,190,.07);">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background:#5B2EBE;color:#D3F94F;">
              <Icon name="film" size={22} />
            </div>
            <h3 class="text-lg font-bold" style="color:#241056;">200,000+ Movies &amp; Series</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:#5B2EBE;">
              A massive on-demand library covering <strong style="color:#241056;">the latest cinema releases, full box-sets, and classic titles.</strong>
              Everything is available on demand: pause, rewind, and watch again. No separate streaming subscription needed.
            </p>
          </div>

          <!-- Card 3 -->
          <div class="rounded-2xl p-7" style="background:#fff;border:1px solid rgba(91,46,190,.12);box-shadow:0 2px 16px rgba(91,46,190,.07);">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background:#5B2EBE;color:#D3F94F;">
              <Icon name="sparkles" size={22} />
            </div>
            <h3 class="text-lg font-bold" style="color:#241056;">True 4K UHD &amp; FHD</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:#5B2EBE;">
              Premium channels stream in <strong style="color:#241056;">native 4K UHD.</strong> If your connection dips, the stream drops to FHD or HD automatically and climbs back. No touching settings, no buffering wheel.
              Crystal-clear picture on every screen size.
            </p>
          </div>

          <!-- Card 4 -->
          <div class="rounded-2xl p-7" style="background:#fff;border:1px solid rgba(91,46,190,.12);box-shadow:0 2px 16px rgba(91,46,190,.07);">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background:#5B2EBE;color:#D3F94F;">
              <Icon name="zap" size={22} />
            </div>
            <h3 class="text-lg font-bold" style="color:#241056;">Anti-Buffer UK Servers</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:#5B2EBE;">
              UK and EU servers load-balanced for <strong style="color:#241056;">99.9% uptime.</strong> We scale capacity before Premier League kick-offs and peak viewing times, not after the first complaints arrive. The stream holds when everyone logs on at once.
            </p>
          </div>

          <!-- Card 5 -->
          <div class="rounded-2xl p-7" style="background:#fff;border:1px solid rgba(91,46,190,.12);box-shadow:0 2px 16px rgba(91,46,190,.07);">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background:#5B2EBE;color:#D3F94F;">
              <Icon name="monitor-smartphone" size={22} />
            </div>
            <h3 class="text-lg font-bold" style="color:#241056;">Works on Every Device</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:#5B2EBE;">
              <strong style="color:#241056;">Amazon Firestick, Smart TV, Android, iOS, Windows, Mac, MAG box, Formuler, Nvidia Shield,</strong> and Apple TV are all supported. No hardware to buy. Open the app, enter your details, and you're watching within minutes.
            </p>
          </div>

          <!-- Card 6 -->
          <div class="rounded-2xl p-7" style="background:#fff;border:1px solid rgba(91,46,190,.12);box-shadow:0 2px 16px rgba(91,46,190,.07);">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background:#5B2EBE;color:#D3F94F;">
              <Icon name="headset" size={22} />
            </div>
            <h3 class="text-lg font-bold" style="color:#241056;">Real UK Support, 24/7</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color:#5B2EBE;">
              Every support message goes to <strong style="color:#241056;">a real person, not a ticket queue.</strong> WhatsApp replies land in under two minutes during UK hours, whether you need first-time setup help or something stopped mid-match.
              Plus a genuine <strong style="color:#241056;">7-day refund window</strong> if the service doesn't perform on your setup.
            </p>
          </div>

        </div>

        <!-- Value callout -->
        <div class="mt-10 rounded-2xl p-8 sm:p-10 text-center" style="background:#5B2EBE;">
