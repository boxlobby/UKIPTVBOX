<style>
  @keyframes border-glow {
    0%, 100% { border-color: rgba(211,249,79,.5); box-shadow: 0 0 0 1px rgba(211,249,79,.35), 0 0 26px rgba(211,249,79,.28); }
    50%       { border-color: rgba(211,249,79,.85); box-shadow: 0 0 0 1px rgba(211,249,79,.65), 0 0 44px rgba(211,249,79,.5); }
  }
  @keyframes btn-float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-6px); }
  }
  .annual-card { animation: border-glow 2.8s ease-in-out infinite; }
  .annual-btn  { animation: btn-float 2.4s ease-in-out infinite; }

  /* FAQ accordion — mirrors Faq.astro */
  .pfaq-item .pfaq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 320ms cubic-bezier(0.4,0,0.2,1);
  }
  .pfaq-item[open]:not(.is-closing) .pfaq-content { grid-template-rows: 1fr; }
  .pfaq-content-inner {
    min-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 240ms ease, transform 320ms cubic-bezier(0.4,0,0.2,1);
  }
  .pfaq-item[open]:not(.is-closing) .pfaq-content-inner { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .pfaq-content, .pfaq-content-inner { transition: none; }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLDetailsElement>('.pfaq-item');
  items.forEach((el) => {
    const summary = el.querySelector('summary');
    const content = el.querySelector<HTMLElement>('.pfaq-content');
    if (!summary || !content) return;
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (el.open) {
        el.classList.add('is-closing');
        const onEnd = (ev: TransitionEvent) => {
          if (ev.propertyName !== 'grid-template-rows') return;
          content.removeEventListener('transitionend', onEnd);
          el.classList.remove('is-closing');
          el.open = false;
        };
        content.addEventListener('transitionend', onEnd);
      } else {
        if (el.name) {
          document.querySelectorAll<HTMLDetailsElement>(`details.pfaq-item[name="${el.name}"][open]`).forEach((s) => {
            if (s === el) return;
            s.classList.add('is-closing');
            const c = s.querySelector<HTMLElement>('.pfaq-content');
            const off = (ev: TransitionEvent) => {
              if (ev.propertyName !== 'grid-template-rows') return;
              c?.removeEventListener('transitionend', off);
              s.classList.remove('is-closing');
              s.open = false;
            };
            c?.addEventListener('transitionend', off);
          });
        }
        el.open = true;
      }
    });
  });
</script>
