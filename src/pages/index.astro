---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CategoryStrip from '../components/CategoryStrip.astro';
import Countries from '../components/Countries.astro';
import Features from '../components/Features.astro';
import Bento from '../components/Bento.astro';
import PricingCard from '../components/PricingCard.astro';
import Devices from '../components/Devices.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import AboutIptv from '../components/AboutIptv.astro';
import Faq from '../components/Faq.astro';
import Articles from '../components/Articles.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <CategoryStrip />
    <PricingCard />
    <Features />
    <Bento />
    <HowItWorks />
    <Devices />
    <Countries />
    <Testimonials />
    <AboutIptv />
    <Faq />
    <Articles />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
