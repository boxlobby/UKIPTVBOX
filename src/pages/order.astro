---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { site, waLink } from '../data/site';
---
<BaseLayout
  title={`Order IPTV UK Trial — ${site.currencySymbol}${site.price} | ${site.name}`}
  description={`Order your ${site.currencySymbol}${site.price} IPTV UK trial. Instant activation on any device.`}
  includeSchema={false}
>
  <Header />
  <main id="main" class="container-x py-24 text-center max-w-2xl mx-auto">
    <span class="eyebrow">Order — coming soon</span>
    <h1 class="mt-6 text-4xl md:text-5xl font-bold">Card checkout coming soon</h1>
    <p class="mt-4 text-text-muted">
      Our secure card checkout is on the way. In the meantime, order your {site.currencySymbol}{site.price} trial in one message via WhatsApp — activated in minutes.
    </p>
    <a href={waLink()} class="btn-primary mt-8" rel="nofollow noopener">
      <Icon name="whatsapp" size={18} /> Order via WhatsApp
    </a>
  </main>
  <Footer />
</BaseLayout>
