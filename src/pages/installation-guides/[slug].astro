---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import FinalCta from '../../components/FinalCta.astro';
import { guides } from '../../data/guides';
import { site, waLink } from '../../data/site';

export async function getStaticPaths() {
  return guides
    .filter((g) => !['smart-tv', 'apple-tv', 'firestick', 'mag-box', 'nvidia-shield', 'enigma2-formuler'].includes(g.slug))
    .map((g) => ({ params: { slug: g.slug }, props: { guide: g } }));
}

const { guide } = Astro.props;
const related = guides.filter((g) => g.slug !== guide.slug).slice(0, 3);
---
<BaseLayout
  title={`${guide.title} | ${site.name}`}
  description={guide.summary}
  includeSchema={false}
>
  <Header />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border-subtle">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-70">
        <div class="absolute -top-40 left-1/2 h-[520px] w-[820px] -translate-x-1/2 rounded-full bg-grad-brand-soft blur-3xl"></div>
      </div>
      <div class="container-x pt-14 pb-12 md:pt-20 md:pb-16 max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-xs uppercase tracking-widest text-text-muted">
          <a href="/" class="hover:text-brand-light">Home</a>
          <span class="mx-2 text-border-subtle">/</span>
          <a href="/installation-guides/" class="hover:text-brand-light">Installation Guides</a>
          <span class="mx-2 text-border-subtle">/</span>
          <span class="text-text-primary">{guide.device}</span>
        </nav>

        <div class="mt-6 flex items-center gap-4">
          <span class="flex h-14 w-14 items-center justify-center rounded-xl border border-brand/20 bg-brand/10 text-brand-light">
            <Icon name={guide.icon} size={28} />
          </span>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">
              {guide.readMinutes} min read · Step-by-step
            </p>
            <span class="eyebrow mt-1 block">{guide.device} setup</span>
          </div>
        </div>

        <h1 class="mt-6 font-display text-3xl md:text-5xl font-bold tracking-tight text-text-primary">
          {guide.title}
        </h1>
        <p class="mt-5 text-lg text-text-muted leading-relaxed">{guide.summary}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waLink(`Hi, I need help setting up IPTV on my ${guide.device}.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            Get activation on WhatsApp
          </a>
          <a href="/installation-guides/" class="btn-secondary">All guides</a>
        </div>
      </div>
    </section>

    <!-- Body -->
    <section class="container-x py-14 md:py-20 max-w-3xl">
      <!-- Quick facts -->
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="card p-5">
          <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">Recommended app</p>
          <p class="mt-2 text-base font-medium text-text-primary">{guide.recommendedApp}</p>
        </div>
        <div class="card p-5">
          <p class="text-[11px] font-semibold uppercase tracking-widest text-text-muted">What you'll need</p>
          <ul class="mt-2 space-y-1.5 text-sm text-text-muted">
            {guide.requirements.map((r) => (
              <li class="flex gap-2">
                <span class="mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center text-brand-light">
                  <Icon name="check" size={14} />
                </span>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Steps -->
      <h2 class="mt-14 font-display text-2xl md:text-3xl font-bold text-text-primary">Step-by-step setup</h2>
      <ol class="mt-8 space-y-6">
        {guide.steps.map((s, i) => (
          <li class="card p-6 md:p-7">
            <div class="flex items-start gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grad-brand text-sm font-bold text-white shadow-glow">
                {i + 1}
              </span>
              <div class="min-w-0">
                <h3 class="text-lg md:text-xl font-semibold text-text-primary">{s.title}</h3>
                <p class="mt-2 text-text-muted leading-relaxed">{s.body}</p>
              </div>
            </div>
          </li>
        ))}
      </ol>

      <!-- Tips -->
      {guide.tips.length > 0 && (
        <>
          <h2 class="mt-14 font-display text-2xl md:text-3xl font-bold text-text-primary">Pro tips</h2>
          <ul class="mt-6 space-y-3">
            {guide.tips.map((t) => (
              <li class="flex gap-3 rounded-xl border border-border-subtle bg-elevated/60 p-4">
                <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand/15 text-brand-light">
                  <Icon name="sparkles" size={14} />
                </span>
                <span class="text-sm text-text-muted leading-relaxed">{t}</span>
              </li>
            ))}
          </ul>
        </>
      )}

      <!-- Help card -->
      <aside class="mt-14 card p-6 md:p-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-text-muted">Stuck?</p>
        <h2 class="mt-2 font-display text-2xl font-semibold text-text-primary">We'll set it up for you</h2>
        <p class="mt-3 text-text-muted">
          Every subscription includes free hands-on setup support. Message us on WhatsApp with your
          device and we'll walk you through it, or activate your playlist remotely.
        </p>
        <div class="mt-6">
          <a href={waLink(`Hi, I need help setting up IPTV on my ${guide.device}.`)} class="btn-primary" target="_blank" rel="nofollow noopener noreferrer">
            <Icon name="whatsapp" size={16} class="mr-2" />
            Chat with UK support
          </a>
        </div>
      </aside>
    </section>

    <!-- Related guides -->
    <section class="section bg-subtle/50 border-t border-border-subtle">
      <div class="container-x">
        <div class="mx-auto max-w-2xl text-center">
          <span class="eyebrow">More guides</span>
          <h2 class="mt-4 text-2xl sm:text-3xl md:text-4xl font-bold">Other installation guides</h2>
        </div>
        <ul class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
          {related.map((g) => (
            <li>
              <a
                href={`/installation-guides/${g.slug}/`}
                class="group card block h-full p-5 transition duration-200 hover:border-brand/50 hover:-translate-y-0.5"
              >
                <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-brand/20 bg-brand/10 text-brand-light">
                  <Icon name={g.icon} size={20} />
                </span>
                <h3 class="mt-4 text-base font-semibold text-text-primary group-hover:text-brand-light">{g.device}</h3>
                <p class="mt-1 text-xs text-text-muted line-clamp-2">{g.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
