---
import Logo from './Logo.astro';
import { site } from '../data/site';
---
<header class="sticky top-0 z-40 border-b border-border-subtle/60 bg-base/85 backdrop-blur-md">
  <div class="container-x flex h-16 sm:h-20 items-center justify-center md:justify-between py-2 sm:py-3">
    <Logo />
    <nav class="hidden md:flex items-center gap-8 text-sm text-text-muted" aria-label="Primary">
      <a href="/#features" class="hover:text-text-primary transition">Features</a>
      <a href="/pricing" class="hover:text-text-primary transition">Pricing</a>
      <a href="/installation-guides/" class="hover:text-text-primary transition">Installation Guides</a>
      <a href="/#faq" class="hover:text-text-primary transition">FAQ</a>
      <a href="/contact" class="hover:text-text-primary transition">Contact</a>
    </nav>
    <div class="hidden md:flex items-center gap-2">
      <a href="/pricing" class="btn-primary inline-flex text-xs sm:text-sm px-4 sm:px-5">
        Get UK IPTV BOX
      </a>
    </div>
  </div>
</header>
