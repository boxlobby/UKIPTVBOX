---
import Icon from './Icon.astro';
import { devices } from '../data/devices';
---
<section id="devices" class="section" style="background:rgba(30,13,72,.55);">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Device compatibility</span>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold">Your IPTV Subscription on <span class="text-brand-light">All Your Devices</span></h2>
      <p class="mt-4 text-text-muted text-sm sm:text-base leading-relaxed">
        One IPTV UK trial, every device, Fire Stick, Smart TV, Android, iOS, MAG and Apple TV.
        Tap yours for a step-by-step IPTV setup guide.
      </p>
    </div>

    <ul class="mt-10 md:mt-14 mb-10 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4">
      {devices.map((d) => (
        <li>
          <a
            href={d.href}
            class="device-card group block h-full p-5 sm:p-6 text-center cursor-pointer transition duration-200 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand/60"
            style="border-radius:1rem;background:rgba(46,23,112,.7);border:1px solid #4A2F9E;box-shadow:none;"
            aria-label={`${d.title} setup guide`}
          >
            <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl transition" style="background:rgba(211,249,79,.1);color:#D3F94F;border:1px solid rgba(211,249,79,.2);">
              <Icon name={d.icon} size={24} />
            </span>
            <h3 class="mt-4 text-base sm:text-lg font-semibold text-text-primary">{d.title}</h3>
            <p class="mt-1 text-xs sm:text-sm text-text-muted">{d.sub}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-[11px] sm:text-xs font-semibold uppercase tracking-widest text-brand-light">
              Setup guide
              <Icon name="arrow" size={14} class="transition-transform group-hover:translate-x-0.5" />
            </span>
          </a>
        </li>
      ))}
    </ul>
    <div class="text-center">
      <a href="/installation-guides/" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-light hover:underline">
        View all installation guides
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
