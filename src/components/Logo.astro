---
export interface Props { class?: string; height?: number }
const { class: className = '', height = 56 } = Astro.props;
const width = Math.round(height * 2);
---
<a href="/" class={`inline-flex items-center ${className}`} aria-label="IPTV Trial, home">
  <img
    src="/logo.png"
    alt="IPTV Trial logo"
    width={width}
    height={height}
    style={`height:${height}px;width:auto`}
    loading="eager"
    decoding="async"
  />
</a>
