---
import { posts } from '../data/posts';

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const SLUGS = [
  'top-5-iptv-boxes-uk-2026',
  'iptv-free-trial-uk',
  'is-iptv-legal-uk',
  'iptv-subscription-uk-buyers-guide',
  'cheap-iptv-uk-scam-or-legit',
  'iptv-smarters-pro-firestick-uk',
];

const articles = SLUGS.map((slug) => {
  const p = posts.find((x) => x.slug === slug)!;
  return {
    title: p.title,
    excerpt: p.excerpt,
    category: p.category,
    date: fmt(p.published),
    href: `/blog/${p.slug}/`,
    image: p.image,
    imageAlt: p.imageAlt,
  };
});
---
<section class="py-14 sm:py-20 bg-subtle/40" aria-label="Latest articles">
  <div class="container-x">
    <div class="text-center mb-10 sm:mb-12">
      <p class="text-[11px] font-medium uppercase tracking-widest text-brand-light mb-3">
        From the blog
      </p>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold tracking-tight text-text-primary">
        Guides, tips & updates
      </h2>
      <p class="mt-3 text-sm sm:text-base text-text-muted max-w-xl mx-auto leading-relaxed">
        Setup walkthroughs and honest buying advice for your UK IPTV subscription.
        Fresh guides on Fire Stick, Smart TV, Android, iOS and MAG, landing regularly.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 mb-8">
      {articles.map((a, i) => (
        <a
          href={a.href}
          class:list={[
            'card group flex flex-col overflow-hidden hover:border-brand/40 transition',
            i >= 3 && 'hidden lg:flex',
          ]}
        >
          <div class="border-b border-border-subtle bg-elevated/40">
            <img
              src={a.image}
              alt={a.imageAlt ?? a.title}
              width="1200"
              height="630"
              loading="lazy"
              decoding="async"
              class="aspect-[16/10] w-full object-cover"
            />
          </div>
          <div class="flex flex-col gap-3 p-5">
            <div class="flex items-center gap-2 text-[11px] font-medium uppercase tracking-widest text-brand-light">
              <span>{a.category}</span>
              {a.date && (
                <>
                  <span class="text-border-subtle">·</span>
                  <span class="text-text-muted normal-case tracking-normal font-normal">{a.date}</span>
                </>
              )}
            </div>
            <h3 class="text-lg font-semibold text-text-primary leading-snug group-hover:text-brand-light transition">
              {a.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">
              {a.excerpt}
            </p>
            <span class="mt-1 text-sm font-medium text-brand-light inline-flex items-center gap-1">
              Read more
              <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-light hover:underline">
        View all guides
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
