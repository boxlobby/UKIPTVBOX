---
import Icon from './Icon.astro';
import { site, waLink } from '../data/site';

const included = [
  '50,000+ live channels (UK & international)',
  'UK, Europe, India & Worldwide',
  'Sports channels, movies and series library',
  'Anti-buffer UK & EU servers, 99.9% uptime',
  '4K UHD, FHD & HD streams',
  'Instant activation',
  'Fully Customisable Channel List',
  'Built-In VPN Protection',
  '24/7 WhatsApp Support',
  'One-time payment, no auto-renewal',
];
---
<section id="pricing" class="section">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">One simple package</span>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold">The {site.currencySymbol}{site.price} IPTV Trial</h2>
      <p class="mt-4 text-text-muted text-sm sm:text-base leading-relaxed">
        A genuine 30-day IPTV UK trial with the full 50,000+ channel lineup, no upsells, no auto-renewal.
        Only upgrade to a long-term IPTV subscription if you love the service.
      </p>
    </div>

    <div class="mt-10 md:mt-14 mx-auto max-w-2xl">
      <div class="animated-border relative rounded-3xl p-[1.5px]">
        <div class="relative z-10 rounded-[calc(1.5rem-1.5px)] bg-elevated p-6 sm:p-8 md:p-10">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div>
              <p class="text-[11px] font-medium uppercase tracking-widest text-brand-light">30-day IPTV UK trial</p>
              <h3 class="mt-2 text-xl sm:text-2xl md:text-3xl font-bold">30 Days IPTV Trial</h3>
            </div>
            <span class="rounded-full bg-brand/15 border border-brand/40 px-3 py-1 text-[11px] font-semibold text-brand-light uppercase tracking-wider">
              Cheapest UK IPTV
            </span>
          </div>

          <div class="mt-6 flex items-end gap-3">
            <span class="text-5xl sm:text-6xl md:text-7xl font-display font-bold leading-none bg-grad-brand bg-clip-text text-transparent">
              {site.currencySymbol}{site.price}
            </span>
          </div>

          <ul class="mt-7 space-y-3">
            {included.map((line) => (
              <li class="flex items-start gap-3 text-sm text-text-primary">
                <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-success/20 text-success shrink-0">
                  <Icon name="check" size={14} />
                </span>
                <span>{line}</span>
              </li>
            ))}
          </ul>

          <p class="mt-8 flex justify-center text-xs sm:text-sm text-text-primary">
            <span class="flex items-center gap-1.5"><Icon name="refresh-ccw" size={14} /> 7-Day Refund Window</span>
          </p>

          <div class="mt-3">
            <a href={waLink()} class="btn-primary w-full py-4 text-base" target="_blank" rel="nofollow noopener noreferrer">
              Get My Trial, {site.currencySymbol}{site.price}
              <Icon name="arrow" size={18} />
            </a>
          </div>

          <p class="mt-6 flex justify-center text-xs text-success">
            <span class="flex items-center gap-1.5"><Icon name="lock" size={14} /> Secure & encrypted payment</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animated-border {
    background: linear-gradient(var(--rot, 0deg), rgba(96, 165, 250, 0.9), rgba(59, 130, 246, 0.15) 30%, rgba(59, 130, 246, 0.05) 60%, rgba(96, 165, 250, 0.9));
    background-size: 200% 200%;
    animation: border-rotate 6s linear infinite;
    isolation: isolate;
  }
  .animated-border::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1.5px;
    background: conic-gradient(from var(--angle, 0deg), transparent 0deg, rgba(96, 165, 250, 0) 200deg, rgba(147, 197, 253, 0.9) 300deg, rgba(96, 165, 250, 0.9) 340deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    animation: border-spin 5s linear infinite;
    pointer-events: none;
    z-index: 1;
  }
  @property --angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  @keyframes border-spin {
    to { --angle: 360deg; }
  }
  @keyframes border-rotate {
    0% { background-position: 0% 0%; }
    100% { background-position: 0% 200%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .animated-border,
    .animated-border::before {
      animation: none;
    }
  }
</style>
