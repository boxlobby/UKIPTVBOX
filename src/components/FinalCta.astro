---
import Icon from './Icon.astro';
import { site } from '../data/site';
---
<section class="section" style="background:#241056;">
  <div class="container-x">
    <div class="relative overflow-hidden rounded-3xl p-8 sm:p-10 md:p-14 text-center" style="background:#5B2EBE;">
      <div class="absolute -top-32 left-1/2 h-72 w-[600px] -translate-x-1/2 rounded-full blur-3xl" style="background:rgba(211,249,79,.22);"></div>
      <div class="absolute -bottom-32 right-0 h-72 w-72 rounded-full blur-3xl" style="background:rgba(251,228,224,.25);"></div>

      <div class="relative">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">
          Get the <span class="bg-grad-brand bg-clip-text text-transparent">Best UK IPTV Subscription</span> Today
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-sm sm:text-base leading-relaxed" style="color:#EAE2FA">
          50,000+ channels, 4K quality, instant activation. Choose from 1, 3, 6 or 12-month plans.
          No auto-renewal, no hidden fees. Just the best IPTV subscription in the UK.
        </p>

        <div class="mt-8 flex justify-center">
          <a href="/#pricing" class="btn-primary px-8 py-4 text-base">
            View UK IPTV BOX Plans
            <Icon name="arrow" size={18} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
