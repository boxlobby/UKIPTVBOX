---
import Icon from './Icon.astro';
import { testimonials } from '../data/testimonials';
import { site } from '../data/site';
---
<section class="section bg-subtle/40">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Loved by UK viewers</span>
      <h2 class="mt-4 text-3xl md:text-5xl font-bold">{site.reviews.rating} / 5 from {site.reviews.count}+ customers</h2>
      <p class="mt-4 text-text-muted">Real customers from London to Glasgow. Setup takes minutes, support responds in under two.</p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <figure class="card p-6">
          <div class="flex items-center gap-1 text-signal">
            {Array.from({ length: t.rating }).map(() => <Icon name="star" size={14} />)}
          </div>
          <blockquote class="mt-4 text-sm text-text-primary leading-relaxed">“{t.body}”</blockquote>
          <figcaption class="mt-5 flex items-center gap-3 text-xs text-text-muted">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-grad-uk font-semibold text-white">
              {t.name.charAt(0)}
            </span>
            <span>
              <span class="block font-semibold text-text-primary">{t.name}</span>
              <span>{t.city}, UK</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
