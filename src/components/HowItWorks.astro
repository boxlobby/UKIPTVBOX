---
import Icon from './Icon.astro';
import Placeholder from './Placeholder.astro';
import { steps } from '../data/steps';
---
<section id="how" class="section">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Setup in 3 steps</span>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold">
        Start your IPTV UK trial in <span class="bg-grad-brand bg-clip-text text-transparent">under 10 minutes</span>
      </h2>
      <p class="mt-4 text-text-muted text-sm sm:text-base">
        No hardware, no long forms, no auto-renewal. Follow three simple steps and you’re watching live TV, sports, movies and series in minutes.
      </p>
    </div>

    <ol class="mt-10 md:mt-16 space-y-6 md:space-y-0 md:grid md:grid-cols-3 md:gap-6">
      {steps.map((s, i) => (
        <li class="card overflow-hidden flex flex-col">
          <div class="relative">
            <Placeholder
              label={s.imgLabel}
              src={s.r2 || undefined}
              alt={s.title}
              aspect="aspect-[4/3]"
              width={800}
              height={600}
            />
            <span class="absolute top-3 left-3 rounded-full bg-base/80 backdrop-blur px-3 py-1 text-[11px] font-semibold text-brand-light border border-brand/40">
              Step {s.n}
            </span>
          </div>

          <div class="p-5 sm:p-6 flex-1 flex flex-col">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand-light">
              <Icon name={s.icon} size={20} />
            </div>
            <h3 class="text-lg sm:text-xl font-semibold text-text-primary">{s.title}</h3>
            <p class="mt-1 text-xs font-medium uppercase tracking-widest text-brand-light">{s.lead}</p>
            <p class="mt-3 text-sm text-text-muted leading-relaxed">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>

    <p class="mt-10 text-center text-sm text-text-muted">
      Ready to test the cheapest UK IPTV trial? <a href="#pricing" class="text-brand-light font-semibold hover:underline">Jump to pricing →</a>
    </p>
  </div>
</section>
