---
import { steps } from '../data/steps';
---
<section id="how" class="section" style="background:#EDEAF5;">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow-light">Get Started</span>
      <h2 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold leading-tight" style="color:#2A1458">
        Start Your UK IPTV Subscription in <span style="color:#5B2EBE">3 Simple Steps</span>
      </h2>
      <p class="mt-4 text-sm sm:text-base leading-relaxed" style="color:#5A4699">
        Your UKIPTVBOX subscription activates in under five minutes, no contracts, no auto-renewal.
        Choose your plan, receive your login on WhatsApp, and start streaming on any device.
      </p>
    </div>

    <ol class="hiw-steps mt-16 grid grid-cols-1 md:grid-cols-3 gap-6 relative">
      {steps.map((s, i) => (
        <li class="hiw-step relative overflow-hidden" style="border-radius:20px;background:#FBE4E0;padding:32px 28px;">
          <span style="position:absolute;top:8px;right:20px;font-size:88px;font-weight:700;line-height:1;color:#C6B5EE;user-select:none;pointer-events:none">{i + 1}</span>
          <span style="display:inline-flex;border-radius:999px;background:#D3F94F;border:1px solid rgba(36,16,86,.2);padding:6px 16px;font-size:13px;font-weight:600;color:#241056;">{s.title}</span>
          <h3 style="margin-top:18px;font-size:19px;font-weight:600;color:#2A1458;position:relative">{s.title}</h3>
          <p style="margin-top:10px;font-size:14px;line-height:1.65;color:#7A5A50;position:relative">{s.body}</p>
        </li>
      ))}
    </ol>

    <p class="mt-12 md:mt-16 text-center text-sm" style="color:#5A4699">
      Ready to get the best UK IPTV subscription? <a href="/#pricing" style="color:#4B22AC;font-weight:600;text-decoration:underline">See all plans →</a>
    </p>
  </div>
</section>

